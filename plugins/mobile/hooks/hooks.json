{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [ { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/smell-checker.sh\"" } ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dart-auto-format.sh\"" },
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/dart-analyze-file.sh\"", "timeout": 30 }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [ { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/package-feedback.sh\"" } ]
      }
    ]
  }
}
