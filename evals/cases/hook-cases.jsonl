# Casos de eval (Tier 1, determinístico) para os hooks reais em plugins/core/hooks/
# e plugins/mobile/hooks/. Placeholders {{TMPDIR}} / {{REPO_ROOT}} são substituídos
# por evals/run-evals.sh antes do parse JSON — ver schema no cabeçalho daquele script.
{"desc": "read-ledger: leitura de arquivo registra range no ledger da sessão", "hook": "plugins/core/hooks/read-ledger.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/plugin-data"}, "input": {"tool_name": "Read", "session_id": "eval-rl-happy", "tool_input": {"file_path": "/fake/path/foo.dart"}, "tool_response": {"content": "     1\tline one\n     2\tline two\n"}}, "expect_exit": 0, "expect_side_file": "{{TMPDIR}}/agent-kit-evals/plugin-data/state/read-ledger-eval-rl-happy.jsonl", "expect_side_file_contains": "foo.dart"}
{"desc": "read-ledger: tool_name fora de Read/Grep não grava ledger", "hook": "plugins/core/hooks/read-ledger.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/plugin-data"}, "input": {"tool_name": "Write", "session_id": "eval-rl-edge", "tool_input": {"file_path": "/fake/path/bar.dart"}}, "expect_exit": 0, "expect_side_file_missing": "{{TMPDIR}}/agent-kit-evals/plugin-data/state/read-ledger-eval-rl-edge.jsonl"}
{"desc": "session-start (bonus, 7º hook): injeta corpo do SKILL.md using-agent-kit", "hook": "plugins/core/hooks/session-start.sh", "env": {"CLAUDE_PLUGIN_ROOT": "{{REPO_ROOT}}/plugins/core"}, "input": {"hook_event_name": "SessionStart", "source": "startup"}, "expect_exit": 0, "expect_contains": "agent-kit-core"}
{"desc": "session-start (bonus): CLAUDE_PLUGIN_ROOT sem SKILL.md falha alto (não silencioso)", "hook": "plugins/core/hooks/session-start.sh", "env": {"CLAUDE_PLUGIN_ROOT": "{{TMPDIR}}/agent-kit-evals/does-not-exist"}, "input": {"hook_event_name": "SessionStart", "source": "startup"}, "expect_exit": 1}
{"desc": "mobile smell-checker: edit limpo em store passa", "hook": "plugins/mobile/hooks/smell-checker.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/mobile-plugin-data"}, "input": {"tool_name": "Edit", "tool_input": {"file_path": "lib/modules/foo/foo_store.dart", "old_string": "int count = 0;", "new_string": "int count = 1;"}}, "expect_exit": 0}
{"desc": "mobile smell-checker: DI001 (GetIt.I em store) bloqueia e loga", "hook": "plugins/mobile/hooks/smell-checker.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/mobile-plugin-data"}, "input": {"tool_name": "Edit", "tool_input": {"file_path": "lib/modules/foo/foo_store.dart", "old_string": "int count = 0;", "new_string": "int count = 0;\n  final repo = GetIt.I<FooRepo>();"}}, "expect_exit": 2, "expect_side_file": "{{TMPDIR}}/agent-kit-evals/mobile-plugin-data/smell-log.txt", "expect_side_file_contains": "DI001"}
{"desc": "mobile smell-checker: ARCH001 (BuildContext em controller) bloqueia", "hook": "plugins/mobile/hooks/smell-checker.sh", "input": {"tool_name": "Edit", "tool_input": {"file_path": "lib/modules/foo/foo_controller.dart", "old_string": "int x = 0;", "new_string": "int x = 0;\n  void go(BuildContext context) { Navigator.of(context).pop(); }"}}, "expect_exit": 2}
{"desc": "mobile smell-checker: LOG001 (print em lib/) bloqueia", "hook": "plugins/mobile/hooks/smell-checker.sh", "input": {"tool_name": "Edit", "tool_input": {"file_path": "lib/modules/foo/foo_util.dart", "old_string": "int x = 0;", "new_string": "int x = 0;\n  print('debug');"}}, "expect_exit": 2}
{"desc": "mobile smell-checker: add-only — padrão já presente no old_string não bloqueia de novo", "hook": "plugins/mobile/hooks/smell-checker.sh", "input": {"tool_name": "Edit", "tool_input": {"file_path": "lib/modules/foo/foo_store.dart", "old_string": "print('already here');", "new_string": "print('already here'); // comment tweak"}}, "expect_exit": 0}
