# Casos de eval (Tier 1, determinístico) para os hooks reais em plugins/core/hooks/
# e plugins/mobile/hooks/. Placeholders {{TMPDIR}} / {{REPO_ROOT}} são substituídos
# por evals/run-evals.sh antes do parse JSON — ver schema no cabeçalho daquele script.
{"desc": "plan-autoload: plano recente (<72h) injeta ponteiro de retomada", "hook": "plugins/core/hooks/plan-autoload.sh", "env": {"CLAUDE_PROJECT_DIR": "{{TMPDIR}}/agent-kit-evals/plan-autoload-happy"}, "input": {"hook_event_name": "SessionStart", "session_id": "eval-pa-happy"}, "expect_exit": 0, "expect_contains": "plan-autoload"}
{"desc": "plan-autoload: plano com mtime >72h não injeta (silêncio)", "hook": "plugins/core/hooks/plan-autoload.sh", "env": {"CLAUDE_PROJECT_DIR": "{{TMPDIR}}/agent-kit-evals/plan-autoload-stale"}, "input": {"hook_event_name": "SessionStart", "session_id": "eval-pa-stale"}, "expect_exit": 0, "expect_not_contains": "plan-autoload"}
{"desc": "bash-autoapprove-readonly: git status é auto-aprovado", "hook": "plugins/core/hooks/bash-autoapprove-readonly.sh", "input": {"tool_name": "Bash", "tool_input": {"command": "git status"}}, "expect_exit": 0, "expect_contains": "allow"}
{"desc": "bash-autoapprove-readonly: git push não é auto-aprovado (defere)", "hook": "plugins/core/hooks/bash-autoapprove-readonly.sh", "input": {"tool_name": "Bash", "tool_input": {"command": "git push origin main"}}, "expect_exit": 0, "expect_not_contains": "allow"}
{"desc": "bash-autoapprove-readonly: git fetch defere (rede não é leitura)", "hook": "plugins/core/hooks/bash-autoapprove-readonly.sh", "input": {"tool_name": "Bash", "tool_input": {"command": "git fetch origin"}}, "expect_exit": 0, "expect_not_contains": "allow"}
{"desc": "bash-autoapprove-readonly: git branch <nome> defere (cria branch); listagem aprova", "hook": "plugins/core/hooks/bash-autoapprove-readonly.sh", "input": {"tool_name": "Bash", "tool_input": {"command": "git branch nova-feature"}}, "expect_exit": 0, "expect_not_contains": "allow"}
{"desc": "bash-autoapprove-readonly: git branch --show-current aprova (consulta)", "hook": "plugins/core/hooks/bash-autoapprove-readonly.sh", "input": {"tool_name": "Bash", "tool_input": {"command": "git branch --show-current"}}, "expect_exit": 0, "expect_contains": "allow"}
{"desc": "bash-autoapprove-readonly: git tag <nome> defere (cria tag)", "hook": "plugins/core/hooks/bash-autoapprove-readonly.sh", "input": {"tool_name": "Bash", "tool_input": {"command": "git tag v1.0.0"}}, "expect_exit": 0, "expect_not_contains": "allow"}
{"desc": "bash-autoapprove-readonly: git tag puro aprova (lista)", "hook": "plugins/core/hooks/bash-autoapprove-readonly.sh", "input": {"tool_name": "Bash", "tool_input": {"command": "git tag"}}, "expect_exit": 0, "expect_contains": "allow"}
{"desc": "bash-autoapprove-readonly: git branch --set-upstream-to=x defere (forma --opt=valor escreve config)", "hook": "plugins/core/hooks/bash-autoapprove-readonly.sh", "input": {"tool_name": "Bash", "tool_input": {"command": "git branch --set-upstream-to=origin/main"}}, "expect_exit": 0, "expect_not_contains": "allow"}
{"desc": "bash-autoapprove-readonly: git branch --contains HEAD aprova (consulta com posicional)", "hook": "plugins/core/hooks/bash-autoapprove-readonly.sh", "input": {"tool_name": "Bash", "tool_input": {"command": "git branch --contains HEAD"}}, "expect_exit": 0, "expect_contains": "allow"}
{"desc": "bash-autoapprove-readonly: git remote set-branches defere (escreve config; deny-list antiga aprovava)", "hook": "plugins/core/hooks/bash-autoapprove-readonly.sh", "input": {"tool_name": "Bash", "tool_input": {"command": "git remote set-branches upstream main"}}, "expect_exit": 0, "expect_not_contains": "allow"}
{"desc": "bash-autoapprove-readonly: git remote -v aprova (consulta)", "hook": "plugins/core/hooks/bash-autoapprove-readonly.sh", "input": {"tool_name": "Bash", "tool_input": {"command": "git remote -v"}}, "expect_exit": 0, "expect_contains": "allow"}
{"desc": "bash-autoapprove-readonly: flutter pub get defere (muta lockfile/cache)", "hook": "plugins/core/hooks/bash-autoapprove-readonly.sh", "input": {"tool_name": "Bash", "tool_input": {"command": "flutter pub get"}}, "expect_exit": 0, "expect_not_contains": "allow"}
{"desc": "bash-autoapprove-readonly: flutter test defere (executa código do repo)", "hook": "plugins/core/hooks/bash-autoapprove-readonly.sh", "input": {"tool_name": "Bash", "tool_input": {"command": "flutter test"}}, "expect_exit": 0, "expect_not_contains": "allow"}
{"desc": "bash-autoapprove-readonly: flutter analyze segue aprovado", "hook": "plugins/core/hooks/bash-autoapprove-readonly.sh", "input": {"tool_name": "Bash", "tool_input": {"command": "flutter analyze"}}, "expect_exit": 0, "expect_contains": "allow"}
{"desc": "read-ledger: leitura de arquivo registra range no ledger da sessão", "hook": "plugins/core/hooks/read-ledger.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/plugin-data"}, "input": {"tool_name": "Read", "session_id": "eval-rl-happy", "tool_input": {"file_path": "/fake/path/foo.dart"}, "tool_response": {"content": "     1\tline one\n     2\tline two\n"}}, "expect_exit": 0, "expect_side_file": "{{TMPDIR}}/agent-kit-evals/plugin-data/state/read-ledger-eval-rl-happy.jsonl", "expect_side_file_contains": "foo.dart"}
{"desc": "read-ledger: tool_name fora de Read/Grep não grava ledger", "hook": "plugins/core/hooks/read-ledger.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/plugin-data"}, "input": {"tool_name": "Write", "session_id": "eval-rl-edge", "tool_input": {"file_path": "/fake/path/bar.dart"}}, "expect_exit": 0, "expect_side_file_missing": "{{TMPDIR}}/agent-kit-evals/plugin-data/state/read-ledger-eval-rl-edge.jsonl"}
{"desc": "claude-dir-guard: rm sem .claude passa", "hook": "plugins/core/hooks/claude-dir-guard.sh", "input": {"tool_name": "Bash", "tool_input": {"command": "rm {{TMPDIR}}/agent-kit-evals/scratch/foo.txt"}}, "expect_exit": 0}
{"desc": "claude-dir-guard: rm + .claude bloqueia", "hook": "plugins/core/hooks/claude-dir-guard.sh", "input": {"tool_name": "Bash", "tool_input": {"command": "rm -rf {{TMPDIR}}/agent-kit-evals/.claude/knowledge-map.tsv"}}, "expect_exit": 2}
{"desc": "session-start (bonus, 7º hook): injeta corpo do SKILL.md using-agent-kit", "hook": "plugins/core/hooks/session-start.sh", "env": {"CLAUDE_PLUGIN_ROOT": "{{REPO_ROOT}}/plugins/core"}, "input": {"hook_event_name": "SessionStart", "source": "startup"}, "expect_exit": 0, "expect_contains": "agent-kit-core"}
{"desc": "session-start (bonus): CLAUDE_PLUGIN_ROOT sem SKILL.md falha alto (não silencioso)", "hook": "plugins/core/hooks/session-start.sh", "env": {"CLAUDE_PLUGIN_ROOT": "{{TMPDIR}}/agent-kit-evals/does-not-exist"}, "input": {"hook_event_name": "SessionStart", "source": "startup"}, "expect_exit": 1}
{"desc": "mobile smell-checker: edit limpo em store passa", "hook": "plugins/mobile/hooks/smell-checker.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/mobile-plugin-data"}, "input": {"tool_name": "Edit", "tool_input": {"file_path": "lib/modules/foo/foo_store.dart", "old_string": "int count = 0;", "new_string": "int count = 1;"}}, "expect_exit": 0}
{"desc": "mobile smell-checker: DI001 (GetIt.I em store) bloqueia e loga", "hook": "plugins/mobile/hooks/smell-checker.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/mobile-plugin-data"}, "input": {"tool_name": "Edit", "tool_input": {"file_path": "lib/modules/foo/foo_store.dart", "old_string": "int count = 0;", "new_string": "int count = 0;\n  final repo = GetIt.I<FooRepo>();"}}, "expect_exit": 2, "expect_side_file": "{{TMPDIR}}/agent-kit-evals/mobile-plugin-data/smell-log.txt", "expect_side_file_contains": "DI001"}
{"desc": "mobile smell-checker: ARCH001 (BuildContext em controller) bloqueia", "hook": "plugins/mobile/hooks/smell-checker.sh", "input": {"tool_name": "Edit", "tool_input": {"file_path": "lib/modules/foo/foo_controller.dart", "old_string": "int x = 0;", "new_string": "int x = 0;\n  void go(BuildContext context) { Navigator.of(context).pop(); }"}}, "expect_exit": 2}
{"desc": "mobile smell-checker: LOG001 (print em lib/) bloqueia", "hook": "plugins/mobile/hooks/smell-checker.sh", "input": {"tool_name": "Edit", "tool_input": {"file_path": "lib/modules/foo/foo_util.dart", "old_string": "int x = 0;", "new_string": "int x = 0;\n  print('debug');"}}, "expect_exit": 2}
{"desc": "mobile smell-checker: add-only — padrão já presente no old_string não bloqueia de novo", "hook": "plugins/mobile/hooks/smell-checker.sh", "input": {"tool_name": "Edit", "tool_input": {"file_path": "lib/modules/foo/foo_store.dart", "old_string": "print('already here');", "new_string": "print('already here'); // comment tweak"}}, "expect_exit": 0}
{"desc": "mobile package-feedback: primeira edição de _test.dart injeta lembrete", "hook": "plugins/mobile/hooks/package-feedback.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/mobile-plugin-data-pf"}, "input": {"session_id": "eval-pf-happy", "tool_input": {"file_path": "test/foo_store_test.dart"}}, "expect_exit": 0, "expect_contains": "package-feedback"}
{"desc": "mobile package-feedback: segunda edição do mesmo _test.dart na mesma sessão fica em silêncio", "hook": "plugins/mobile/hooks/package-feedback.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/mobile-plugin-data-pf"}, "input": {"session_id": "eval-pf-happy", "tool_input": {"file_path": "test/foo_store_test.dart"}}, "expect_exit": 0, "expect_not_contains": "package-feedback"}
# Os 2 casos abaixo são SMOKE TESTS (hook roda, exit 0, {} em input fora de escopo) — NÃO isolam guard:
# mutation test provou que passam com os guards removidos (o guard de existência-de-arquivo produz o mesmo
# {} p/ fixture inexistente, e sem dart o curto-circuito da toolchain idem). Cobertura guard-isolating é
# inatingível em tier-1 (e p/ o caso não-.dart, em tier-2 também — dart analyze não emite stdout p/ não-Dart).
{"desc": "mobile dart-analyze-file (smoke, não guard-isolating): edit não-.dart → advisory vazio e exit 0", "hook": "plugins/mobile/hooks/dart-analyze-file.sh", "input": {"tool_name": "Edit", "tool_input": {"file_path": "docs/notes.md"}}, "expect_exit": 0, "expect_contains": "{}"}
{"desc": "mobile dart-analyze-file (smoke, não guard-isolating): edit .g.dart → advisory vazio e exit 0", "hook": "plugins/mobile/hooks/dart-analyze-file.sh", "input": {"tool_name": "Edit", "tool_input": {"file_path": "lib/modules/foo/foo_view.g.dart"}}, "expect_exit": 0, "expect_contains": "{}"}
