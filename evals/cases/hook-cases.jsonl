# Casos de eval (Tier 1, determinístico) para os hooks reais em plugins/core/hooks/
# e plugins/mobile/hooks/. Placeholders {{TMPDIR}} / {{REPO_ROOT}} são substituídos
# por evals/run-evals.sh antes do parse JSON — ver schema no cabeçalho daquele script.
{"desc": "read-ledger: leitura de arquivo registra range no ledger da sessão", "hook": "plugins/core/hooks/read-ledger.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/plugin-data"}, "input": {"tool_name": "Read", "session_id": "eval-rl-happy", "tool_input": {"file_path": "/fake/path/foo.dart"}, "tool_response": {"content": "     1\tline one\n     2\tline two\n"}}, "expect_exit": 0, "expect_side_file": "{{TMPDIR}}/agent-kit-evals/plugin-data/state/read-ledger-eval-rl-happy.jsonl", "expect_side_file_contains": "foo.dart"}
{"desc": "read-ledger: tool_name fora de Read/Grep não grava ledger", "hook": "plugins/core/hooks/read-ledger.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/plugin-data"}, "input": {"tool_name": "Write", "session_id": "eval-rl-edge", "tool_input": {"file_path": "/fake/path/bar.dart"}}, "expect_exit": 0, "expect_side_file_missing": "{{TMPDIR}}/agent-kit-evals/plugin-data/state/read-ledger-eval-rl-edge.jsonl"}
{"desc": "session-start (bonus, 7º hook): injeta corpo do SKILL.md using-agent-kit", "hook": "plugins/core/hooks/session-start.sh", "env": {"CLAUDE_PLUGIN_ROOT": "{{REPO_ROOT}}/plugins/core"}, "input": {"hook_event_name": "SessionStart", "source": "startup"}, "expect_exit": 0, "expect_contains": "agent-kit-core"}
{"desc": "session-start (bonus): CLAUDE_PLUGIN_ROOT sem SKILL.md falha alto (não silencioso)", "hook": "plugins/core/hooks/session-start.sh", "env": {"CLAUDE_PLUGIN_ROOT": "{{TMPDIR}}/agent-kit-evals/does-not-exist"}, "input": {"hook_event_name": "SessionStart", "source": "startup"}, "expect_exit": 1}
{"desc": "mobile smell-checker: edit limpo em store passa", "hook": "plugins/mobile/hooks/smell-checker.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/mobile-plugin-data"}, "input": {"tool_name": "Edit", "tool_input": {"file_path": "lib/modules/foo/foo_store.dart", "old_string": "int count = 0;", "new_string": "int count = 1;"}}, "expect_exit": 0}
{"desc": "mobile smell-checker: DI001 (GetIt.I em store) bloqueia e loga", "hook": "plugins/mobile/hooks/smell-checker.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/mobile-plugin-data"}, "input": {"tool_name": "Edit", "tool_input": {"file_path": "lib/modules/foo/foo_store.dart", "old_string": "int count = 0;", "new_string": "int count = 0;\n  final repo = GetIt.I<FooRepo>();"}}, "expect_exit": 2, "expect_side_file": "{{TMPDIR}}/agent-kit-evals/mobile-plugin-data/smell-log.txt", "expect_side_file_contains": "DI001"}
{"desc": "mobile smell-checker: ARCH001 (BuildContext em controller) bloqueia", "hook": "plugins/mobile/hooks/smell-checker.sh", "input": {"tool_name": "Edit", "tool_input": {"file_path": "lib/modules/foo/foo_controller.dart", "old_string": "int x = 0;", "new_string": "int x = 0;\n  void go(BuildContext context) { Navigator.of(context).pop(); }"}}, "expect_exit": 2}
{"desc": "mobile smell-checker: LOG001 (print em lib/) bloqueia", "hook": "plugins/mobile/hooks/smell-checker.sh", "input": {"tool_name": "Edit", "tool_input": {"file_path": "lib/modules/foo/foo_util.dart", "old_string": "int x = 0;", "new_string": "int x = 0;\n  print('debug');"}}, "expect_exit": 2}
{"desc": "mobile smell-checker: add-only — padrão já presente no old_string não bloqueia de novo", "hook": "plugins/mobile/hooks/smell-checker.sh", "input": {"tool_name": "Edit", "tool_input": {"file_path": "lib/modules/foo/foo_store.dart", "old_string": "print('already here');", "new_string": "print('already here'); // comment tweak"}}, "expect_exit": 0}
{"desc": "codegen-staleness: fonte com part .g.dart e gerado STALE avisa build_runner", "hook": "plugins/mobile/hooks/codegen-staleness.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/codegen-data-1"}, "input": {"hook_event_name": "PostToolUse", "tool_input": {"file_path": "{{TMPDIR}}/agent-kit-evals/codegen-fixture/lib/stale_store.dart", "new_string": "@observable int x = 1;"}}, "expect_exit": 2, "expect_contains": "build_runner"}
{"desc": "codegen-staleness: gerado FRESCO (mais novo que a fonte) silencia", "hook": "plugins/mobile/hooks/codegen-staleness.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/codegen-data-2"}, "input": {"hook_event_name": "PostToolUse", "tool_input": {"file_path": "{{TMPDIR}}/agent-kit-evals/codegen-fixture/lib/fresh_store.dart", "new_string": "@observable int x = 1;"}}, "expect_exit": 0}
{"desc": "codegen-staleness: segunda edicao do mesmo arquivo na sessao silencia (marker)", "hook": "plugins/mobile/hooks/codegen-staleness.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/codegen-data-1"}, "input": {"hook_event_name": "PostToolUse", "tool_input": {"file_path": "{{TMPDIR}}/agent-kit-evals/codegen-fixture/lib/stale_store.dart", "new_string": "@observable int y = 2;"}}, "expect_exit": 0}
{"desc": "codegen-staleness: arquivo sem part directive silencia", "hook": "plugins/mobile/hooks/codegen-staleness.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/codegen-data-3"}, "input": {"hook_event_name": "PostToolUse", "tool_input": {"file_path": "{{TMPDIR}}/agent-kit-evals/codegen-fixture/lib/plain.dart", "new_string": "final int x = 1;"}}, "expect_exit": 0}
{"desc": "lifecycle: adicionar ReactionDisposer em store sem dispose avisa", "hook": "plugins/mobile/hooks/lifecycle-check.sh", "input": {"hook_event_name": "PostToolUse", "tool_input": {"file_path": "{{TMPDIR}}/agent-kit-evals/lifecycle-fixture/lib/no_dispose_store.dart", "old_string": "class S {", "new_string": "class S {\n  late ReactionDisposer _r;"}}, "expect_exit": 2, "expect_contains": "dispose"}
{"desc": "lifecycle: arquivo com dispose() presente silencia", "hook": "plugins/mobile/hooks/lifecycle-check.sh", "input": {"hook_event_name": "PostToolUse", "tool_input": {"file_path": "{{TMPDIR}}/agent-kit-evals/lifecycle-fixture/lib/has_dispose_store.dart", "old_string": "class S {", "new_string": "class S {\n  late ReactionDisposer _r;"}}, "expect_exit": 0}
{"desc": "lifecycle: edicao que NAO adiciona recurso descartavel silencia (add-only)", "hook": "plugins/mobile/hooks/lifecycle-check.sh", "input": {"hook_event_name": "PostToolUse", "tool_input": {"file_path": "{{TMPDIR}}/agent-kit-evals/lifecycle-fixture/lib/no_dispose_store.dart", "old_string": "int x = 1;", "new_string": "int x = 2;"}}, "expect_exit": 0}
{"desc": "di-mismatch: @injectable adicionado e classe ausente do injection.config.dart avisa", "hook": "plugins/mobile/hooks/di-mismatch.sh", "env": {"CLAUDE_PROJECT_DIR": "{{TMPDIR}}/agent-kit-evals/di-fixture"}, "input": {"hook_event_name": "PostToolUse", "tool_input": {"file_path": "{{TMPDIR}}/agent-kit-evals/di-fixture/lib/new_service.dart", "old_string": "class NewService {", "new_string": "@injectable\nclass NewService {"}}, "expect_exit": 2, "expect_contains": "injection.config.dart"}
{"desc": "di-mismatch: classe ja registrada no injection.config.dart silencia", "hook": "plugins/mobile/hooks/di-mismatch.sh", "env": {"CLAUDE_PROJECT_DIR": "{{TMPDIR}}/agent-kit-evals/di-fixture"}, "input": {"hook_event_name": "PostToolUse", "tool_input": {"file_path": "{{TMPDIR}}/agent-kit-evals/di-fixture/lib/old_service.dart", "old_string": "class OldService {", "new_string": "@injectable\nclass OldService {"}}, "expect_exit": 0}
{"desc": "di-mismatch: edicao sem anotacao DI silencia (add-only)", "hook": "plugins/mobile/hooks/di-mismatch.sh", "env": {"CLAUDE_PROJECT_DIR": "{{TMPDIR}}/agent-kit-evals/di-fixture"}, "input": {"hook_event_name": "PostToolUse", "tool_input": {"file_path": "{{TMPDIR}}/agent-kit-evals/di-fixture/lib/new_service.dart", "old_string": "int x = 1;", "new_string": "int x = 2;"}}, "expect_exit": 0}
# --- posture-signal (council, 2026-07-13): proactive posture/checkpoint signaling on UserPromptSubmit ---
{"desc": "posture-signal: done-claim sugere grill-me pre-done", "hook": "plugins/council/hooks/posture-signal.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/posture-data-1"}, "input": {"hook_event_name": "UserPromptSubmit", "session_id": "eval-ps-1", "prompt": "acho que ta pronto, podemos commitar?"}, "expect_exit": 0, "expect_contains": "grill-me pre-done"}
{"desc": "posture-signal: escolha A-ou-B sugere bohr", "hook": "plugins/council/hooks/posture-signal.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/posture-data-1"}, "input": {"hook_event_name": "UserPromptSubmit", "session_id": "eval-ps-1", "prompt": "devo usar Riverpod ou Bloc nesse modulo?"}, "expect_exit": 0, "expect_contains": "council:bohr"}
{"desc": "posture-signal: duas hipoteses vivas sugere schrodinger", "hook": "plugins/council/hooks/posture-signal.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/posture-data-1"}, "input": {"hook_event_name": "UserPromptSubmit", "session_id": "eval-ps-1", "prompt": "esse crash pode ser cache velho ou race condition no init"}, "expect_exit": 0, "expect_contains": "council:schrodinger"}
{"desc": "posture-signal: prompt comum silencia (sem falso positivo)", "hook": "plugins/council/hooks/posture-signal.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/posture-data-1"}, "input": {"hook_event_name": "UserPromptSubmit", "session_id": "eval-ps-1", "prompt": "adiciona um botao na tela de login e ajusta o padding do card"}, "expect_exit": 0, "expect_not_contains": "posture-signal"}
{"desc": "posture-signal: slash command silencia (iniciativa do usuario vence)", "hook": "plugins/council/hooks/posture-signal.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/posture-data-1"}, "input": {"hook_event_name": "UserPromptSubmit", "session_id": "eval-ps-1", "prompt": "/council:bohr hook ou prosa?"}, "expect_exit": 0, "expect_not_contains": "posture-signal"}
{"desc": "posture-signal: mesmo sinal na mesma sessao silencia (marker once-per-session)", "hook": "plugins/council/hooks/posture-signal.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/posture-data-1"}, "input": {"hook_event_name": "UserPromptSubmit", "session_id": "eval-ps-1", "prompt": "escolher entre sqlite e hive aqui, qual dos dois?"}, "expect_exit": 0, "expect_not_contains": "council:bohr"}
{"desc": "posture-signal: prompt casando 2 sinais emite so o de maior prioridade", "hook": "plugins/council/hooks/posture-signal.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/posture-data-2"}, "input": {"hook_event_name": "UserPromptSubmit", "session_id": "eval-ps-2", "prompt": "ta pronto? ou devo usar outra abordagem ou manter essa?"}, "expect_exit": 0, "expect_contains": "grill-me pre-done", "expect_not_contains": "council:bohr"}
{"desc": "posture-signal: sinal prioritario ja marcado cai pro proximo sinal disponivel (continue)", "hook": "plugins/council/hooks/posture-signal.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/posture-data-2"}, "input": {"hook_event_name": "UserPromptSubmit", "session_id": "eval-ps-2", "prompt": "ta pronto? ou devo usar outra abordagem ou manter essa?"}, "expect_exit": 0, "expect_contains": "council:bohr"}
{"desc": "posture-signal: nova sessao re-sinaliza o mesmo sinal (marker por-sessao)", "hook": "plugins/council/hooks/posture-signal.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/posture-data-1"}, "input": {"hook_event_name": "UserPromptSubmit", "session_id": "eval-ps-3", "prompt": "qual dos dois caminhos seguimos?"}, "expect_exit": 0, "expect_contains": "council:bohr"}
# --- blind-review fixes (2026-07-13): each case pins a false-negative the final review found ---
{"desc": "codegen-staleness: nova sessao re-avisa o mesmo arquivo (marker por-sessao, nao por-maquina)", "hook": "plugins/mobile/hooks/codegen-staleness.sh", "env": {"CLAUDE_PLUGIN_DATA": "{{TMPDIR}}/agent-kit-evals/codegen-data-1"}, "input": {"hook_event_name": "PostToolUse", "session_id": "sess-B", "tool_input": {"file_path": "{{TMPDIR}}/agent-kit-evals/codegen-fixture/lib/stale_store.dart", "new_string": "@observable int z = 3;"}}, "expect_exit": 2, "expect_contains": "build_runner"}
{"desc": "di-mismatch: nome de classe prefixo de uma registrada NAO e falso-negativo (word-boundary)", "hook": "plugins/mobile/hooks/di-mismatch.sh", "env": {"CLAUDE_PROJECT_DIR": "{{TMPDIR}}/agent-kit-evals/di-fixture"}, "input": {"hook_event_name": "PostToolUse", "tool_input": {"file_path": "{{TMPDIR}}/agent-kit-evals/di-fixture/lib/prefix.dart", "old_string": "class Old {", "new_string": "@injectable\nclass Old {"}}, "expect_exit": 2, "expect_contains": "injection.config.dart"}
{"desc": "lifecycle: adiciona recurso novo ao lado de um ja existente (add-only por contagem)", "hook": "plugins/mobile/hooks/lifecycle-check.sh", "input": {"hook_event_name": "PostToolUse", "tool_input": {"file_path": "{{TMPDIR}}/agent-kit-evals/lifecycle-fixture/lib/no_dispose_store.dart", "old_string": "Timer? _t;", "new_string": "Timer? _t;\n  StreamSubscription? _s;"}}, "expect_exit": 2, "expect_contains": "dispose"}
{"desc": "di-mismatch: nova classe injetavel ao lado de uma ja anotada (add-only por contagem)", "hook": "plugins/mobile/hooks/di-mismatch.sh", "env": {"CLAUDE_PROJECT_DIR": "{{TMPDIR}}/agent-kit-evals/di-fixture"}, "input": {"hook_event_name": "PostToolUse", "tool_input": {"file_path": "{{TMPDIR}}/agent-kit-evals/di-fixture/lib/pair.dart", "old_string": "@injectable\nclass OldService {}", "new_string": "@injectable\nclass OldService {}\n@injectable\nclass BrandNew {}"}}, "expect_exit": 2, "expect_contains": "injection.config.dart"}
